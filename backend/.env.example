# Required
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/prepup
JWT_SECRET=your-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
NODE_ENV=production
PORT=5000
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173
FRONTEND_URL=https://your-frontend.onrender.com

# Optional — email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=PrepUp <noreply@yourdomain.com>

# Optional — Twilio WhatsApp
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional — cron endpoints (inactive reminders, digests, daily challenge)
CRON_SECRET=

# Optional — platform integrations
GITHUB_TOKEN=
PYTHON_API_URL=

# Optional — MongoDB Atlas API (auto-opens IP for Render)
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_GROUP_ID=
ATLAS_ALLOW_ANYWHERE=0
